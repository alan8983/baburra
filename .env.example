# ============================================================================
# Investment Idea Monitor — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser bundle.
# ============================================================================

# ── Supabase (Required) ─────────────────────────────────────────────────────
# Project URL and public anon key from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key — server-only, bypasses RLS. Keep secret!
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Supabase CLI (Required for CLI operations) ────────────────────────────
# Personal access token for Supabase CLI. Generate at:
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your_supabase_access_token

# Database password for Supabase CLI link/push operations.
# Found in: Supabase Dashboard → Project Settings → Database → Database password
SUPABASE_DB_PASSWORD=your_supabase_db_password

# ── External APIs (Required) ────────────────────────────────────────────────
# Google Gemini API key for AI sentiment analysis and argument extraction
GEMINI_API_KEY=your_gemini_api_key

# Tiingo API token for stock price data
TIINGO_API_TOKEN=your_tiingo_api_token

# Deepgram API key for long-video speech-to-text transcription (Nova-2)
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── App Configuration (Required for production) ─────────────────────────────
# Base URL of the application (used for auth callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI Configuration (Optional) ─────────────────────────────────────────────
# Comma-separated model fallback chain. Tried in order; quota errors (429) roll over.
# Default: gemma-4-31b-it,gemma-4-26b-a4b-it,gemini-2.5-flash-lite
# AI_MODEL_CHAIN=gemma-4-31b-it,gemma-4-26b-a4b-it,gemini-2.5-flash-lite

# Legacy: pin a single model with no fallback. Overrides AI_MODEL_CHAIN if set.
# AI_SENTIMENT_MODEL=gemini-2.5-flash-lite

# ── Scraping & Monitoring (Optional) ────────────────────────────────────────
# YouTube Data API v3 key for channel scraping
YOUTUBE_DATA_API_KEY=your_youtube_data_api_key

# twitterapi.io key for Twitter/X profile scraping
TWITTERAPI_IO_KEY=your_twitterapi_io_key

# Apify API token for TikTok and Facebook scraping via managed Actors
# Get your token at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_api_token

# Secret for cron job endpoints (generate a random string)
CRON_SECRET=your_cron_secret

# ── Development Only (Optional) ─────────────────────────────────────────────
# Bypass authentication in development. Set to a valid user UUID.
# Only active when NODE_ENV !== 'production'. NEVER set in production!
# DEV_USER_ID=00000000-0000-0000-0000-000000000001
