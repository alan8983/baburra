{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/session-setup.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:ai.google.dev)",
      "Bash(Select-String -Pattern \"quick-input|use-quick-input|url\\\\.ts|input.page|ai\\\\.service\")",
      "Bash(npx vitest run:*)",
      "Bash(xargs:*)",
      "Bash(ls:*)"
    ]
  }
}
