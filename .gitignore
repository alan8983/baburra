# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/e2e/test-results/
/e2e/playwright-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# claude code
.claude/worktrees/
.claude/session-status.txt
.claude/repo-map.txt
.claude/.setup-cache/

# seed scrape logs
scripts/logs/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
